{
    "manifest_version": 3,
    "name": "PhishGuard SOC",
    "version": "2.0",
    "description": "Real-time phishing detection with ML, blockchain logging, and threat intelligence.",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}